generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          String         @default("EMPLOYEE") // ADMIN, EMPLOYEE
  isWFH         Boolean        @default(false)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  assignedTasks TaskAssignee[]
  uploadedFiles File[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  attendances   Attendance[]

  projectRoles           UserProjectRole[]
  dailyResponsibilities  UserDailyResponsibility[]
  dailyTaskLogs          DailyTaskLog[]
}

model Project {
  id          String        @id @default(cuid())
  name        String
  clientName  String
  clientPhone String?
  clientEmail String?
  address     String?
  location    String?
  description String?
  status      String        @default("ACTIVE")
  priority    String        @default("MEDIUM")
  deadline    DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tasks       Task[]
  files       File[]
}

model Task {
  id          String       @id @default(cuid())
  name        String
  category    String       // SITE_INSPECTION, FLOOR_PLAN, etc.
  status      String       @default("PENDING")
  priority    String       @default("MEDIUM")
  progress    Int          @default(0) // 0-100%
  deadline    DateTime?
  notes       String?

  // Time Tracking & Delegation
  allottedHours            Int?
  startedAt                DateTime?
  timeSpentMs              Int          @default(0)
  lastTimerStart           DateTime?
  completedAt              DateTime?
  extensionRequestedHours  Int?
  extensionReason          String?

  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  dependsOnId String?
  dependsOn   Task?        @relation("TaskDependencies", fields: [dependsOnId], references: [id])
  unlocks     Task[]       @relation("TaskDependencies")

  assignees   TaskAssignee[]
  files       File[]
}

model TaskAssignee {
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model File {
  id          String   @id @default(cuid())
  name        String
  url         String
  type        String   // e.g., pdf, dwg, image/png
  size        Int      // in bytes
  
  uploadedById String
  uploader    User     @relation(fields: [uploadedById], references: [id])
  
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  type      String   // e.g., TASK_COMPLETED, DEADLINE_MISSED
  isRead    Boolean  @default(false)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String   // e.g., CREATED, UPDATED, DELETED
  entityType String   // e.g., PROJECT, TASK, FILE
  entityId   String
  details    String?
  
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
}

model Attendance {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime  // Stored as Date without time
  clockIn   DateTime
  clockOut  DateTime?
  status    String    @default("PRESENT") // PRESENT, HALF_DAY, LATE

  createdAt DateTime  @default(now())
}

model ProjectRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  
  users       UserProjectRole[]
}

model UserProjectRole {
  userId        String
  projectRoleId String
  
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectRole   ProjectRole @relation(fields: [projectRoleId], references: [id], onDelete: Cascade)
  
  @@id([userId, projectRoleId])
}

model DailyResponsibility {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  
  users       UserDailyResponsibility[]
  logs        DailyTaskLog[]
}

model UserDailyResponsibility {
  userId                String
  dailyResponsibilityId String
  
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyResponsibility DailyResponsibility @relation(fields: [dailyResponsibilityId], references: [id], onDelete: Cascade)
  
  @@id([userId, dailyResponsibilityId])
}

model DailyTaskLog {
  id                     String   @id @default(cuid())
  userId                 String
  dailyResponsibilityId  String
  date                   DateTime // e.g. start of day
  status                 String   @default("PENDING") // PENDING, COMPLETED
  completedAt            DateTime?

  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyResponsibility DailyResponsibility @relation(fields: [dailyResponsibilityId], references: [id], onDelete: Cascade)

  @@unique([userId, dailyResponsibilityId, date])
}
